{
  "name": "timebox",
  "version": "0.2.0",
  "description": "Freelance time tracking desktop app",
  "main": "main.js",
  "bin": {
    "timebox": "./cli/index.js"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "start": "npm run dev",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test": "npm rebuild better-sqlite3 && node --test cli/__tests__/*.test.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.timebox.app",
    "productName": "Timebox",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "db/**/*",
      "cli/**/*",
      "build/**/*",
      "renderer-dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "cli/standalone.js",
        "to": "timebox"
      },
      {
        "from": "cli/mcp-server.js",
        "to": "timebox-mcp"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    }
  }
}
