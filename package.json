{
  "name": "timebox",
  "version": "0.9.1",
  "description": "Freelance time tracking desktop app",
  "license": "MIT",
  "author": "Valerio Galano",
  "repository": {
    "type": "git",
    "url": "https://github.com/valeriogalano/Timebox.git"
  },
  "homepage": "https://github.com/valeriogalano/Timebox#readme",
  "main": "main.js",
  "bin": {
    "timebox": "./cli/index.js"
  },
  "scripts": {
    "predev": "electron-rebuild -f -w better-sqlite3",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "build": "vite build",
    "start": "npm run dev",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "test": "npm rebuild better-sqlite3 && node --test cli/__tests__/*.test.js",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:linux": "npm run build && electron-builder --linux AppImage"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "electron": "^31.7.7",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "dev.valeriogalano.timebox",
    "productName": "Timebox",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "afterPack": "build/after-pack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**/*",
      "db/**/*",
      "cli/**/*",
      "build/**/*",
      "renderer-dist/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "valeriogalano",
        "repo": "Timebox",
        "releaseType": "release"
      }
    ],
    "extraResources": [
      {
        "from": "cli/standalone.js",
        "to": "timebox"
      },
      {
        "from": "cli/mcp-server.js",
        "to": "timebox-mcp"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "identity": null,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "Office",
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
